{
  "functions": {
    "source": "functions",
    "runtime": "nodejs20",
    "codebase": "default"
  },
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": [
    {
      "target": "main",
      "public": "build",
      "ignore": [
        "firebase.json",
        ".DS_Store",
        "**/.DS_Store",
        ".git",
        "**/.git/**",
        ".firebase",
        "**/.firebase/**",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|png|jpg|jpeg|svg|ico|gif)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
          "source": "/registerSW.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/sw-custom.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/manifest.json",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/medical.webmanifest",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/creator.webmanifest",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/business.webmanifest",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "/studios.webmanifest",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "**",
          "headers": [
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            { "key": "Permissions-Policy", "value": "camera=(self), microphone=(self), geolocation=(self)" },
            { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
            { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://apis.google.com https://www.gstatic.com https://www.google.com https://www.googletagmanager.com https://www.recaptcha.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.google.com https://*.google-analytics.com https://*.recaptcha.net wss://*.firebaseio.com; frame-src 'self' https://*.firebaseapp.com https://*.google.com https://www.youtube.com https://youtube.com https://youtu.be https://www.recaptcha.net" }
          ]
        }
      ],
      "redirects": [
        { "source": "/terms", "destination": "/terms.html", "type": 301 },
        { "source": "/privacy", "destination": "/privacy.html", "type": 301 }
      ],
      "rewrites": [
        { "source": "/login", "destination": "/index.html" },
        { "source": "/medical/**", "destination": "/index.html" },
        { "source": "/medical", "destination": "/index.html" },
        { "source": "/legal/**", "destination": "/index.html" },
        { "source": "/legal", "destination": "/index.html" },
        { "source": "/engineering/**", "destination": "/index.html" },
        { "source": "/engineering", "destination": "/index.html" },
        { "source": "/business/**", "destination": "/index.html" },
        { "source": "/business", "destination": "/index.html" },
        { "source": "/individual/**", "destination": "/index.html" },
        { "source": "/individual", "destination": "/index.html" },
        { "source": "/trading/**", "destination": "/index.html" },
        { "source": "/trading", "destination": "/index.html" },
        { "source": "/automotive/**", "destination": "/index.html" },
        { "source": "/automotive", "destination": "/index.html" },
        { "source": "/marketing/**", "destination": "/index.html" },
        { "source": "/marketing", "destination": "/index.html" },
        { "source": "/travel/**", "destination": "/index.html" },
        { "source": "/travel", "destination": "/index.html" },
        { "source": "/transportation/**", "destination": "/index.html" },
        { "source": "/transportation", "destination": "/index.html" },
        { "source": "/retail/**", "destination": "/index.html" },
        { "source": "/retail", "destination": "/index.html" },
        { "source": "/aquaculture/**", "destination": "/index.html" },
        { "source": "/aquaculture", "destination": "/index.html" },
        { "source": "/creator/**", "destination": "/index.html" },
        { "source": "/creator", "destination": "/index.html" },
        { "source": "/studios/**", "destination": "/index.html" },
        { "source": "/studios", "destination": "/index.html" },
        { "source": "/dr/**", "destination": "/index.html" },
        { "source": "/dr", "destination": "/index.html" },
        { "source": "/lawyer/**", "destination": "/index.html" },
        { "source": "/lawyer", "destination": "/index.html" },
        { "source": "/engineer/**", "destination": "/index.html" },
        { "source": "/engineer", "destination": "/index.html" },
        { "source": "/biz/**", "destination": "/index.html" },
        { "source": "/biz", "destination": "/index.html" },
        { "source": "/personal/**", "destination": "/index.html" },
        { "source": "/personal", "destination": "/index.html" },
        { "source": "/trader/**", "destination": "/index.html" },
        { "source": "/trader", "destination": "/index.html" },
        { "source": "/auto/**", "destination": "/index.html" },
        { "source": "/auto", "destination": "/index.html" },
        { "source": "/transport/**", "destination": "/index.html" },
        { "source": "/transport", "destination": "/index.html" },
        { "source": "/aqua/**", "destination": "/index.html" },
        { "source": "/aqua", "destination": "/index.html" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "target": "admin",
      "public": "build-admin",
      "ignore": [
        "firebase.json",
        ".DS_Store",
        "**/.DS_Store",
        ".git",
        "**/.git/**",
        ".firebase",
        "**/.firebase/**",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.@(js|css|woff2|png|jpg|jpeg|svg|ico|gif)",
          "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
        },
        {
          "source": "admin.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }]
        },
        {
          "source": "**",
          "headers": [
            { "key": "X-Frame-Options", "value": "DENY" },
            { "key": "X-Content-Type-Options", "value": "nosniff" },
            { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
            { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
            { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
            { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://apis.google.com https://www.gstatic.com https://www.google.com https://www.googletagmanager.com https://www.recaptcha.net; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https: blob:; connect-src 'self' https://*.googleapis.com https://*.firebaseio.com https://*.firebaseapp.com https://*.google.com https://*.google-analytics.com https://*.recaptcha.net wss://*.firebaseio.com; frame-src 'self' https://*.firebaseapp.com https://*.google.com https://www.youtube.com https://youtube.com https://youtu.be https://www.recaptcha.net" }
          ]
        }
      ],
      "rewrites": [
        { "source": "**", "destination": "/admin.html" }
      ]
    }
  ]
}
