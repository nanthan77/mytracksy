rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ════════════════════════════════════════════════════════════
    //  USER DOCUMENT
    //  Users can only read/write their own profile.
    // ════════════════════════════════════════════════════════════
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;

      // ─── Chart of Accounts ────────────────────────────────────
      //  Users can fully manage their own categories.
      match /chart_of_accounts/{accountId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ─── Transactions (The Core Engine) ───────────────────────
      //  Users can read all their own transactions.
      //  Users can create/update/delete MANUAL transactions.
      //  Users CANNOT modify source or amount_cents on email_auto_sync entries
      //  (only Cloud Functions / admin SDK can write those fields).
      match /transactions/{transactionId} {
        allow read: if request.auth != null && request.auth.uid == userId;

        // Allow create for manual sources
        allow create: if request.auth != null
                      && request.auth.uid == userId
                      && request.resource.data.source in ['manual_entry', 'voice_ai', 'receipt_scan'];

        // Allow update — but protect email_auto_sync fields
        allow update: if request.auth != null
                      && request.auth.uid == userId
                      && (
                        // If source is NOT email_auto_sync, allow full update
                        resource.data.source != 'email_auto_sync'
                        ||
                        // If source IS email_auto_sync, only allow status changes
                        // (user can approve/ignore but cannot change amount or source)
                        (
                          request.resource.data.source == resource.data.source
                          && request.resource.data.amount_cents == resource.data.amount_cents
                          && request.resource.data.idempotency_key == resource.data.idempotency_key
                        )
                      );

        // Allow delete only for manual entries
        allow delete: if request.auth != null
                      && request.auth.uid == userId
                      && resource.data.source in ['manual_entry', 'voice_ai', 'receipt_scan'];
      }

      // ─── Settings ─────────────────────────────────────────────
      match /settings/{settingId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }

      // ─── Legacy collections (backward compat, read-only) ─────
      match /income/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
      match /expenses/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
      match /receipts/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
      match /channeling/{docId} {
        allow read: if request.auth != null && request.auth.uid == userId;
      }
    }

    // ════════════════════════════════════════════════════════════
    //  Legacy flat collections (phase-out — read-only for migration)
    // ════════════════════════════════════════════════════════════
    match /expenses/{expenseId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /budgets/{budgetId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /categories/{categoryId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    match /notifications/{notificationId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    match /notificationSettings/{settingsId} {
      allow read, write: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
    }
    match /income/{incomeId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}