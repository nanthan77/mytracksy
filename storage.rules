rules_version = '2';

// MyTracksy Sri Lanka - Firebase Storage Security Rules
// Secure rules for user data, exports, and application assets
service firebase.storage {
  match /b/{bucket}/o {
    
    // Public assets (app icons, logos, etc.)
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false; // Only admins can update via Firebase Console
    }
    
    // User-specific data (exports, receipts, documents)
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      // Additional validation for file types and sizes
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && request.resource.contentType.matches('.*/(pdf|csv|xlsx|json|png|jpg|jpeg)');
    }
    
    // Family shared documents (when family sharing is enabled)
    match /families/{familyId}/{allPaths=**} {
      allow read, write: if request.auth != null 
                         && request.auth.uid in resource.metadata.familyMembers;
    }
    
    // Export files (temporary, auto-expire)
    match /exports/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId
                         && request.time < resource.timeCreated + duration.value(24, 'h'); // 24-hour expiry
    }
    
    // Bank integration documents (highly secure)
    match /banking/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId
                         && request.auth.token.email_verified == true
                         && request.resource.contentType.matches('.*/pdf');
    }
    
    // Investment documents and reports
    match /investments/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId
                         && request.resource.size < 5 * 1024 * 1024; // 5MB limit
    }
    
    // Business intelligence reports (for enterprise users)
    match /reports/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null 
                         && request.auth.uid == userId
                         && request.auth.token.email_verified == true;
    }
    
    // Backup files (restricted access)
    match /backups/{userId}/{allPaths=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null 
                   && request.auth.uid == userId
                   && request.resource.contentType == 'application/json';
    }
    
    // Admin-only access (for system maintenance)
    match /admin/{allPaths=**} {
      allow read, write: if request.auth != null 
                         && request.auth.token.email in [
                           'admin@tracksy.lk',
                           'support@tracksy.lk'
                         ];
    }
    
    // Default deny rule (security fallback)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}